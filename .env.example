# ─────────────────────────────────────────────────────────────────────────────
#  Adzy.pro — dev environment template
#  Copy to .env and fill in secrets before running docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=adzy
POSTGRES_USER=adzy
POSTGRES_PASSWORD=adzy_dev_password

# ── Backend ───────────────────────────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-to-a-random-256-bit-secret
REFRESH_SECRET_KEY=change-me-to-another-random-256-bit-secret
SESSION_SECRET=change-me-session-secret

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+asyncpg://adzy:adzy_dev_password@pgbouncer:6432/adzy
DATABASE_URL_SYNC=postgresql://adzy:adzy_dev_password@postgres:5432/adzy

REDIS_URL=redis://redis:6379/0

FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Email (Mailpit catches all in dev — no real SMTP needed) ──────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
# Set these only for production (Resend):
RESEND_API_KEY=
EMAIL_FROM=noreply@adzy.pro
VERIFICATION_TOKEN_EXPIRE_HOURS=24
RESEND_COOLDOWN_MINUTES=2

# ── S3 / MinIO (dev uses local MinIO) ─────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
CDN_BASE_URL=http://localhost:9000/adzy-gigs
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=adzy-gigs
S3_RAW_PREFIX=raw/
S3_PROCESSED_PREFIX=gigs/
PRESIGN_EXPIRY_SECONDS=300
MAX_IMAGE_MB=10
MAX_VIDEO_MB=100

# ── OAuth (Google) — optional in dev ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Payments (Razorpay) — use test keys in dev ────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── AI (optional in dev) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development
WATCHPACK_POLLING=true

# ── Scoring ───────────────────────────────────────────────────────────────────
NEW_SCORING_TRAFFIC_PCT=5
